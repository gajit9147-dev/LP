{
  "name": "lp",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "tailwindcss -i ./styles.css -o ./output.css --watch",
    "build": "tailwindcss -i ./styles.css -o ./output.css --minify",
    "start": "serve . -l 5173",
    "lint": "eslint . --ext .js --ignore-pattern eslint.config.js",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.5"
  }
}
